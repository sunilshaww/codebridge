{
  "manifest_version": 3,
  "name": "CodeBridge from Bunchhh",
  "short_name": "CodeBridge",
  "version": "1.0.0",
  "description": "Paste your Workspace ID. AI connects to your local project. Works on Claude.ai, ChatGPT, Gemini.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CodeBridge from Bunchhh"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}