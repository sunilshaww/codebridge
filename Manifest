{
  "manifest_version": 3,
  "name": "CodeBridge from Bunchhh",
  "short_name": "CodeBridge",
  "version": "1.0.0",
  "description": "Connect your local project to Claude, ChatGPT or Gemini. AI reads and fixes your code directly. No copy-paste. No API key. By Bunchhh.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CodeBridge from Bunchhh"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}