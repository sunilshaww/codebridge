// CodeBridge from Bunchhh — background.js

chrome.runtime.onInstalled.addListener(() => {
  console.log('⚡ CodeBridge from Bunchhh installed.');
});

// Relay messages between popup and content scripts
chrome.runtime.onMessage.addListener((msg, sender, sendResponse) => {
  if (msg.type === 'CB_ADD_FIX' || msg.type === 'CB_APPLY_FIX') {
    // Forward to popup if open — handled there
    sendResponse({ok: true});
  }
  return true;
});